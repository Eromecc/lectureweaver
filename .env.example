# Optional server-only provider configuration.
# Copy to .env.local for live analysis or OpenAI audio. Never commit real keys and never
# rename these to NEXT_PUBLIC_*; the browser must not receive provider secrets.
# ChatGPT/Codex subscription quota is separate and cannot fund these API calls.

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
# Uploaded completed-recording transcription; no live microphone/realtime mode.
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe-diarize
# Enhanced-note audio study guide.
OPENAI_TTS_MODEL=gpt-4o-mini-tts

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

KIMI_API_KEY=
KIMI_MODEL=kimi-k3
# cn -> https://api.moonshot.cn/v1; global -> https://api.moonshot.ai/v1
KIMI_REGION=cn
